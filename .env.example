# Copy to `.env` on the server (outside git). Never commit `.env`.
#
# IMPORTANT: Place this file in the same directory as `manage.py` (project root).
# The app loads `.env` from that folder so email works under Passenger/cPanel even
# when the server process cwd is not the project directory.

# --- Production (easternlogistics.app + Namecheap Passenger) ---
DEBUG=False
SECRET_KEY=use-a-long-random-string-not-this-example
ALLOWED_HOSTS=easternlogistics.app,www.easternlogistics.app
CSRF_TRUSTED_ORIGINS=https://easternlogistics.app,https://www.easternlogistics.app
SITE_URL=https://easternlogistics.app

# Django Sites (password reset, absolute URLs). Domain sync runs from SITE_URL / PASSWORD_RESET_DOMAIN on startup.
SITE_ID=1
PASSWORD_RESET_DOMAIN=easternlogistics.app

# SSL terminates at Namecheap/Apache; Django must trust X-Forwarded-Proto (auto if PASSENGER_APP_ENV is set)
BEHIND_TLS_PROXY=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# SQLite outside public_html (example — use your home directory path)
# SQLITE_PATH=/home/USERNAME/private/parcel_delivery/db.sqlite3
# MEDIA_ROOT_PATH=/home/USERNAME/private/parcel_delivery/media

ADMIN_URL=admin/

# --- SMTP (Zoho Mail) ---
# Create a real mailbox (e.g. support@) in Zoho; use its email + app password here.
# The mailbox must exist and be allowed to send as DEFAULT_FROM_EMAIL.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=support@easternlogistics.app
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=20

# Visible From: line (should match an authorized Zoho sender)
DEFAULT_FROM_EMAIL=Eastern Logistics <support@easternlogistics.app>
# Optional: error mail From (defaults to DEFAULT_FROM_EMAIL)
# SERVER_EMAIL=Eastern Logistics <support@easternlogistics.app>

# Optional: receive "new lead" copies at a real inbox (only if SEND_ADMIN_LEAD_EMAIL=True).
# Use a personal or team inbox — not a non-existent support@ alias.
# LEAD_NOTIFICATION_TO_EMAIL=you@gmail.com

# --- SMTP (Gmail / Google Workspace) example ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# Use an app password if 2FA is on; EMAIL_HOST_USER must be the Gmail account.

# --- EU Zoho ---
# EMAIL_HOST=smtp.zoho.eu

RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_VERIFY_REQUEST_TIMEOUT=10

# Controlled email automation
SEND_WELCOME_EMAIL=True
SEND_ADMIN_LEAD_EMAIL=False
SEND_WHATSAPP_LEAD_ALERT=False
SEND_BREVO_CONFIRMATION=False
TWILIO_WEBHOOK_PUBLIC_URL=https://easternlogistics.app/dashboard/twilio-webhook/

# Celery + Redis (background welcome email sending)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
