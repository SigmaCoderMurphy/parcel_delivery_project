# Copy to `.env` and fill in secrets (`.env` is gitignored).

# --- Core security / deployment ---
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SITE_URL=https://yourdomain.com
ADMIN_URL=secure-admin-path/
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# --- Brevo Email Service (For CONFIRMATION EMAILS ONLY) ---
# Get your API Key from: https://app.brevo.com/settings/keys/api
# This is used ONLY for automated confirmation emails when users submit forms
# All other emails (quotes, follow-ups) are sent manually by staff
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=support@yourdomain.com
BREVO_SENDER_NAME=Eastern Logistics

# --- Outbound email for admin notifications (Zoho) ---
# Optional: You can also use Brevo for admin notifications by changing EMAIL_HOST settings
# Current setup: Zoho for admin notifications, Brevo for customer confirmations
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=support@easternlogistics.app
EMAIL_HOST_PASSWORD=your-zoho-app-password-here
DEFAULT_FROM_EMAIL=support@easternlogistics.app

# --- Google reCAPTCHA v2 (Checkbox) ---
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_PUBLIC_KEY=6Le_YOUR_SITE_KEY_HERE_v2_checkbox
RECAPTCHA_PRIVATE_KEY=6Le_YOUR_SECRET_KEY_HERE_v2_checkbox

# Optional: proxy SSL header when using Nginx reverse proxy
# SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
